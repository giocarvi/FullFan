SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://user:password@host:port/database

# Max Player Public API
# Nunca guardar el token real en git; configúralo como variable privada en Railway.
MAXPLAYER_API_BASE=https://api.maxplayer.tv/v3/api/public
MAXPLAYER_API_TOKEN=replace-with-maxplayer-token
MAXPLAYER_DOMAIN_ID=1

# Solo para instalaciones nuevas. En producción existente no deberían usarse
# contraseñas por defecto; cambia/rota usuarios desde el panel.
DEFAULT_ADMIN_PASSWORD=replace-me
DEFAULT_ATENCION_PASSWORD=replace-me
DEFAULT_JACKYE_PASSWORD=replace-me
DEFAULT_INGRID_PASSWORD=replace-me
DEFAULT_TURCIOS_PASSWORD=replace-me

BRAND_NAME=Fénix Digital TV
BRAND_TAGLINE=Tu entretenimiento, sin fronteras.
